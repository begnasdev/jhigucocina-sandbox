# =============================================================================
# PURPOSE
#   Template for the client (Vite) environment configuration. Copy to
#   .env.development / .env.staging / .env.production (or .env.local for a
#   developer's machine) and fill per Firebase project.
#
# EXPLANATION
#   Document D §9 mandates three ISOLATED Firebase projects (dev/staging/prod),
#   same source, config-by-environment. This replaces the hardcoded firebaseConfig
#   that previously lived in src/firebase/firebase.js. Vite exposes only vars
#   prefixed with VITE_ to the client bundle.
#
#   VITE_USE_EMULATORS toggles the local Emulator Suite connection (Document D §7).
#   When "true", the client connects to the emulators instead of a live project.
#
# DEPLOYMENT
#   - Local dev:     cp .env.example .env.local   (set VITE_USE_EMULATORS=true)
#   - CI builds:     CI injects the correct .env.<target> per environment.
#   - NEVER commit real .env.* files (see .gitignore). Only .env.example is tracked.
# =============================================================================

# Which environment this build targets: development | staging | production
VITE_APP_ENV=development

# Connect to the local Firebase Emulator Suite instead of a live project.
VITE_USE_EMULATORS=true

# Default tenant (matches config/providerConfig.js DEFAULT_PROVIDER_ID).
VITE_DEFAULT_PROVIDER_ID=jhigucocina

# --- Firebase project web config (from Firebase console > Project settings) ---
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# App Check (Document D §9). reCAPTCHA site key per environment.
VITE_APPCHECK_RECAPTCHA_SITE_KEY=
